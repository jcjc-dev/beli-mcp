{
  "name": "beli-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Reverse-engineered Beli API contract (zod-first) and an MCP server.",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -b && npm run build --workspace beli-mcp",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "lint": "eslint .",
    "gen:openapi": "npm run gen:openapi --workspace @beli/contract",
    "clean": "rm -rf packages/*/dist packages/*/*.tsbuildinfo"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
