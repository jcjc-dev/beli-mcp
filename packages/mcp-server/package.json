{
  "name": "beli-mcp",
  "version": "0.1.0",
  "description": "MCP server for Beli — log in once, then search places, rank reviews, manage photos and bookmarks via tools.",
  "license": "MIT",
  "author": "Jason C (jcjc-dev)",
  "type": "module",
  "mcpName": "io.github.jcjc-dev/beli-mcp",
  "homepage": "https://github.com/jcjc-dev/beli-mcp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jcjc-dev/beli-mcp.git",
    "directory": "packages/mcp-server"
  },
  "bugs": {
    "url": "https://github.com/jcjc-dev/beli-mcp/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "beli-mcp": "dist/cli.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit",
    "inspector": "npx @modelcontextprotocol/inspector node dist/cli.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "mcp-server",
    "beli",
    "restaurants",
    "dining",
    "reviews",
    "food",
    "claude",
    "claude-desktop",
    "cursor",
    "anthropic",
    "ai-tools"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@beli/client": "0.1.0",
    "@beli/contract": "0.1.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "optionalDependencies": {
    "@napi-rs/keyring": "^1.3.0"
  }
}
